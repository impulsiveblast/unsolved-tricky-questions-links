class Solution {
  public:
    int minPlatform(vector<int>& arr, vector<int>& dep) {
        // code here
        
        int count=0,i=0,j=0,maxcount=0;
        
        sort(arr.begin(),arr.end());
        
        sort(dep.begin(),dep.end());
        
        
        while(i<arr.size())
        {
           
            if(arr[i]<=dep[j])
            {
                count++;
                
                i++;
                
            }
            else
            {
                count--;
                
                j++;
            }
            
            maxcount=max(count,maxcount);
            
        }
        
        
        return maxcount;
        
    }
};


