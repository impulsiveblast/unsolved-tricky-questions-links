   int majorityElement(vector<int>& nums) {
        
       int count=1,max_n=nums[0];

       for(int i=1;i<nums.size();i++)
       {
        if(nums[i]==max_n)
        {
            count++;
        }
        else
        {
            if(count>1)
            {
                count--;
            }
            else
            {
                max_n= nums[i];
                count=1;
            }
        }
       }


       count=0;

       for(int i=0;i<nums.size();i++)
       {
        if(nums[i]==max_n)
        {
            count++;
        }
       }


      if(count>nums.size()/2)
      {
        return max_n;
      }
 return -1;
}


