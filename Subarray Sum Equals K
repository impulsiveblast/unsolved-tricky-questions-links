class Solution {
public:
    int subarraySum(vector<int>& nums, int k) {
        
      int i=0,j=0,sum=0,count=0;

      map<int,vector<int>> m;

      while(j<nums.size())
      {

           sum+=nums[j];

           m[sum].push_back(j);

           if(sum==k)
           {
             count++;
           }  
         
         if(m[sum-k].size()>0)
         {
            if(m[sum-k][m[sum-k].size()-1]==j )
            {
                count+=m[sum-k].size()-1;
            }
            else{
            count+=m[sum-k].size();
            }
         }
       

       j++;
          
      }


      return count;

    }
};


