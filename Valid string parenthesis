class Solution {
public:
    bool checkValidString(string s) {
       

       int count=0,sum=0,min=0,max=0;

       for(int i=0;i<s.size();i++)
       {
         if(s[i]=='(')
         {
            min+=1;
            max+=1;
         }
         else if(s[i]==')')
         {
            min-=1;
            max-=1;

            
         }
         else if(s[i]=='*')
         {
             min=min-1;
             max=max+1;

            //  if(min<0)
            //  {
            //     min=0;
            //  }

             
         }

         if(min<0)
            {
                min=0;
            }


         if(max<0)
         {
            return false;
         }
       }


// int t=count*(-1);
               if(min<=0 && max>=0)
               {
                return true;
               }

               return false;
    }
};




